# ─── SyncVoice AI - Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── App Settings ────────────────────────────────────────────────────────────
SYNCVOICE_DEBUG=true
SYNCVOICE_LOG_LEVEL=DEBUG
SYNCVOICE_MULTI_TENANT=false

# ─── STT - Speaches (Local Whisper Server) ───────────────────────────────────
SPEACHES_BASE_URL=http://localhost:8000
SPEACHES_API_KEY=syncvoice-local
SPEACHES_MODEL=whisper-1
SPEACHES_USE_WEBSOCKET=true

# ─── LLM - Ollama ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_STREAM=true
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=512
OLLAMA_CONTEXT_LENGTH=4096

# ─── TTS - Kokoro ────────────────────────────────────────────────────────────
# Leave KOKORO_MODEL_PATH empty to auto-download
KOKORO_MODEL_PATH=
KOKORO_VOICE=af_bella
KOKORO_DEVICE=cpu
KOKORO_SPEED=1.0

# ─── LiveKit - WebRTC Transport ──────────────────────────────────────────────
# Sign up for free at https://livekit.io/cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
LIVEKIT_ROOM_NAME=syncvoice-room
LIVEKIT_IDENTITY=syncvoice-agent

# ─── Google Calendar API ─────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project -> Enable Google Calendar API
# 3. Create OAuth 2.0 credentials -> Download as JSON
# 4. Save as config/google_credentials.json
GOOGLE_CALENDAR_CREDENTIALS_FILE=config/google_credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=config/google_token.json

# ─── ChromaDB (Vector Knowledge Base) ────────────────────────────────────────
CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION_NAME=syncvoice_knowledge

# ─── n8n Automation (Optional) ──────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_ENABLED=false

# ─── Phone Provider (Future) ─────────────────────────────────────────────────
PHONE_PROVIDER=
PHONE_ACCOUNT_SID=
PHONE_AUTH_TOKEN=
PHONE_FROM_NUMBER=

# ─── Audio Settings ──────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FRAME_DURATION_MS=20
VAD_THRESHOLD=0.5
VAD_FRAME_DURATION_MS=30
SILENCE_TIMEOUT_SECONDS=1.5

# ─── Analytics ───────────────────────────────────────────────────────────────
ANALYTICS_ENABLED=true
ANALYTICS_DB_PATH=data/analytics.db
